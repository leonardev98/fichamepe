# Obligatorios y no vacíos (passport-jwt falla con ""). Usa valores distintos en producción.
JWT_SECRET=change-me-access-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-different-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Sin Postgres aún: true = SQLite en memoria (solo desarrollo). Con Docker Postgres: false
DATABASE_USE_SQLITE=true
# Solo obligatorias si DATABASE_USE_SQLITE no es true (Postgres real)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=fichamepe
DATABASE_PASSWORD=fichamepe123
DATABASE_NAME=fichamepe_dev
# Opcional hasta integrar S3: déjalas vacías o comenta; el backend arranca igual.
# Los endpoints de uploads responderán 503 hasta que configures las cuatro.
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
APP_PORT=3001
# Origen del frontend (CORS con credentials)
CORS_ORIGIN=http://localhost:3000

# Obligatorios y no vacíos (passport-jwt falla con ""). Usa valores distintos en producción.
JWT_SECRET=change-me-access-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-different-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Cookies de sesión (refresh). En desarrollo: Lax. En producción sin variable: SameSite=None+Secure
#   (Vercel + API en otro host). Pon AUTH_COOKIE_SAMESITE=lax solo si front y API son mismo site
#   registrable (ej. https://fichamepe.com y https://api.fichamepe.com).
# AUTH_COOKIE_SAMESITE=lax
# Sin Postgres: true = SQLite en memoria (solo desarrollo). Con Postgres real: false
DATABASE_USE_SQLITE=true
# Solo obligatorias si DATABASE_USE_SQLITE no es true (Postgres real)
# Postgres local en WSL: DATABASE_HOST suele ser localhost o la IP del host Windows si el servidor escucha ahí.
#
# Supabase (Dashboard → Database → Connection string):
#   DATABASE_PASSWORD = "Database password" del proyecto (no anon / sb_publishable_*).
#   SSL: si el host contiene supabase.co se activa solo; si no, DATABASE_SSL=true
#
# WSL2: el host directo db.<ref>.supabase.co a menudo solo resuelve a IPv6 y falla (ENETUNREACH).
# Usa Session pooler (misma contraseña): host aws-0-<region>.pooler.supabase.com, user postgres.<ref>
#   Ej. East US (us-east-1): DATABASE_HOST=aws-0-us-east-1.pooler.supabase.com
#   DATABASE_USER=postgres.bgbihnohcykrewzxputn   # postgres + ref del subdominio del proyecto
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=fichamepe
DATABASE_PASSWORD=fichamepe123
DATABASE_NAME=fichamepe_dev
# DATABASE_SSL=true
# Opcional hasta integrar S3: déjalas vacías o comenta; el backend arranca igual.
# Los endpoints de uploads responderán 503 hasta que configures las cuatro.
# AWS_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# Tras subir con POST /uploads/presign, el backend devuelve publicUrl (virtual-hosted:
#   https://<bucket>.s3.<region>.amazonaws.com/<key>
# ). Guárdala en profiles.avatar_url; el bucket debe permitir lectura pública de esos objetos (o CDN).
# CORS del bucket (S3 → Permissions → CORS): permite PUT desde tu frontend, p. ej.
#   AllowedMethods: GET, PUT, HEAD; AllowedHeaders: *; AllowedOrigins: http://localhost:3000 y tu dominio.
# Opcional: correos extra (coma) sin límite práctico de publicaciones (además de rol admin).
# REFERRAL_PUBLISH_EXEMPT_EMAILS=
# Precios de slots permanentes (PEN); por defecto 19 y 49 si se omiten.
# PUBLICATION_SLOT_PRICE_PEN=19
# PUBLICATION_PACK3_PRICE_PEN=49
APP_PORT=3001
# CORS (cookies/credentials). Vacío o * = cualquier dominio (refleja Origin).
# Un solo URL añade automáticamente apex + www (ej. https://fichamepe.com y https://www.fichamepe.com).
# Varios explícitos (sin ampliar www): CORS_ORIGIN=https://a.com,https://b.com
# CORS_ORIGIN=
# Fuera de producción el API devuelve resetToken en POST /auth/forgot-password para completar el flujo en el modal (sin correo SMTP).
# PASSWORD_RESET_DEV_LINK=true
#
# --- Verificación de correo (Resend) ---
# 1) Cuenta en https://resend.com → API Keys → crear clave → pegar aquí.
# 2) Dominios → Añadir dominio (ej. fichame.pe) → copiar registros DNS (SPF, DKIM) en tu proveedor DNS y esperar "Verified".
# 3) MAIL_FROM debe usar un remitente de ese dominio verificado, ej: "Equipo <noreply@fichame.pe>"
#    En pruebas sin dominio propio puedes usar solo la API de prueba de Resend con remitente tipo onboarding@resend.dev
#    (limitado a enviar solo a tu propio correo según la doc de Resend).
# 4) FRONTEND_URL = URL pública del Next (enlace "Verificar correo" del email). Local: http://localhost:3000
# Si RESEND_API_KEY está vacío, el backend solo escribe el enlace de verificación en los logs (útil en local).
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM="Equipo fichame.pe <noreply@fichame.pe>"
FRONTEND_URL=http://localhost:3000

# --- Railway (API): copia solo lo que necesites al panel de variables ---
# Raíz del repo como "Root Directory" del servicio; ver railway.toml en la raíz.
# NODE_ENV=production
# (Opcional) AUTH_COOKIE_SAMESITE=lax si API y web son mismo site registrable; si no pones nada, en prod ya va None.
# CORS_ORIGIN vacío o * = el backend refleja el Origin (vale para empezar).
# FRONTEND_URL sin texto extra en la misma línea (en Railway no uses // comentarios pegados al valor).
#
# --- Google OAuth (opcional; las tres variables deben existir para habilitar el botón) ---
# En Google Cloud → Credenciales → Cliente OAuth web:
#   - "URI de redirección autorizada" = EXACTAMENTE la URL del **API Nest** (no la del Next.js):
#       https://<tu-api>/auth/google/callback
#     Ej. Railway: https://tu-servicio.up.railway.app/auth/google/callback
#   - Nunca pongas aquí solo https://fichamepe.com/... salvo que ese host apunte al Nest y resuelva en DNS.
# Variables:
#   GOOGLE_CLIENT_ID=...
#   GOOGLE_CLIENT_SECRET=...
#   GOOGLE_CALLBACK_URL=https://<mismo-host-que-el-api>/auth/google/callback
# FRONTEND_URL = URL pública del Next (tras login el API redirige al usuario allí).
# Si entras al login desde un origen distinto (p. ej. preview de Vercel), añade ese origen a CORS_ORIGIN
# separado por comas para que el retorno OAuth use ese mismo dominio (además de FRONTEND_URL).
